<script type="module">
  const loadGsap = () =>
    Promise.all([
      import('https://esm.sh/gsap@3.12.5'),
      import('https://esm.sh/gsap@3.12.5/ScrollTrigger')
    ]);

  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const backToTop = document.getElementById('back-to-top');
  const themeToggleDark = document.getElementById('theme-toggle-dark');
  const themeToggleLight = document.getElementById('theme-toggle-light');
  const floatingThemeDark = document.getElementById('floating-theme-dark');
  const floatingThemeLight = document.getElementById('floating-theme-light');
  const floatingAgenda = document.getElementById('floating-agenda');

  // Theme toggle
  const currentTheme = localStorage.getItem('theme') || 'dark';
  const isLight = currentTheme === 'light';

  const setTheme = (lightMode) => {
    document.body.classList.toggle('light-mode', lightMode);
    localStorage.setItem('theme', lightMode ? 'light' : 'dark');

    if (!themeToggleDark || !themeToggleLight || !floatingThemeDark || !floatingThemeLight) return;

    themeToggleDark.classList.toggle('hidden', lightMode);
    themeToggleLight.classList.toggle('hidden', !lightMode);
    floatingThemeDark.classList.toggle('hidden', lightMode);
    floatingThemeLight.classList.toggle('hidden', !lightMode);

    themeToggleDark.setAttribute('aria-pressed', (!lightMode).toString());
    themeToggleLight.setAttribute('aria-pressed', lightMode.toString());
    floatingThemeDark.setAttribute('aria-pressed', (!lightMode).toString());
    floatingThemeLight.setAttribute('aria-pressed', lightMode.toString());
  };

  if (themeToggleDark && themeToggleLight && floatingThemeDark && floatingThemeLight) {
    setTheme(isLight);

    themeToggleDark.addEventListener('click', () => setTheme(true));
    themeToggleLight.addEventListener('click', () => setTheme(false));
    floatingThemeDark.addEventListener('click', () => setTheme(true));
    floatingThemeLight.addEventListener('click', () => setTheme(false));
  }

  if (toggle && menu) {
    menu.dataset.open = 'false';
    toggle.addEventListener('click', () => {
      const open = menu.dataset.open === 'true';
      menu.dataset.open = (!open).toString();
      toggle.setAttribute('aria-expanded', (!open).toString());
      menu.setAttribute('aria-hidden', open.toString());
      menu.style.scale = open ? '1 0' : '1 1';
      menu.style.opacity = open ? '0' : '1';
    });

    // Cerrar el menú al hacer clic en cualquier enlace
    const menuLinks = menu.querySelectorAll('a');
    menuLinks.forEach(link => {
      link.addEventListener('click', () => {
        menu.dataset.open = 'false';
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.style.scale = '1 0';
        menu.style.opacity = '0';
      });
    });
  }

  // Animación del header: se oculta al bajar y aparece al subir
  if (header && toolbar) {
    loadGsap().then(([gsapModule, scrollTriggerModule]) => {
      const gsap = gsapModule.gsap || gsapModule.default || gsapModule;
      const ScrollTrigger = scrollTriggerModule.ScrollTrigger || scrollTriggerModule.default;
      gsap.registerPlugin(ScrollTrigger);

      const showAnim = gsap.from(toolbar, {
        yPercent: -100,
        paused: true,
        duration: 0.25,
        ease: 'power2.out'
      }).progress(1);

      ScrollTrigger.create({
        start: 'top top',
        end: 'max',
        onUpdate: (self) => {
          header.classList.toggle('header-compact', self.progress > 0.05);
          self.direction === -1 ? showAnim.play() : showAnim.reverse();
        }
      });
    }).catch((err) => {
      console.error('No se pudo cargar GSAP/ScrollTrigger', err);
    });
  }

  if (backToTop && floatingThemeDark && floatingThemeLight && floatingAgenda) {
    window.addEventListener('scroll', () => {
      const show = window.scrollY > 320;
      
      if (show) {
        // Mostrar: back to top → whatsapp → modo tema
        setTimeout(() => backToTop.classList.add('show'), 0);
        setTimeout(() => floatingAgenda.classList.add('show'), 100);
        setTimeout(() => {
          if (!floatingThemeDark.classList.contains('hidden')) {
            floatingThemeDark.classList.add('show');
          }
          if (!floatingThemeLight.classList.contains('hidden')) {
            floatingThemeLight.classList.add('show');
          }
        }, 200);
      } else {
        // Ocultar: modo tema → whatsapp → back to top
        floatingThemeDark.classList.remove('show');
        floatingThemeLight.classList.remove('show');
        setTimeout(() => floatingAgenda.classList.remove('show'), 100);
        setTimeout(() => backToTop.classList.remove('show'), 200);
      }
    });

    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
